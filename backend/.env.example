# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vision_europe_africa
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_SSL=false

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRES=24h

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_CHAT_ID=-100your_admin_group_chat_id

# ── URLs ──────────────────────────────────────────────────────────────────────
DASHBOARD_URL=https://visioneuropeafrica.com
ALLOWED_ORIGINS=https://visioneuropeafrica.com,https://www.visioneuropeafrica.com

# ── Email (optional — Nodemailer) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Vision Europe Africa <noreply@visioneuropeafrica.com>

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
